# Window
window-decoration = true
title = Ghostty
window-width = 200
window-height = 60

# Scrollback
scrollback-limit = 100000

# Font
font-family = SauceCodePro NF
font-family-bold = SauceCodePro NF
font-family-italic = SauceCodePro NF
font-family-bold-italic = SauceCodePro NF
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = 14
font-thicken = true

# Catppuccin Mocha colors
background = #1e1e2e
foreground = #cdd6f4

# Cursor
cursor-color = #f5e0dc
cursor-text = #1e1e2e
cursor-style = block
cursor-style-blink = false

# Selection
selection-background = #f5e0dc
selection-foreground = #1e1e2e

# Normal colors
palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#bac2de

# Bright colors
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#f5c2e7
palette = 14=#94e2d5
palette = 15=#a6adc8

# Indexed colors
palette = 16=#fab387
palette = 17=#f5e0dc

# Shell integration (mark prompts, jump between commands, etc.)
shell-integration = detect
shell-integration-features = no-cursor

# Copy/clipboard
copy-on-select = clipboard
mouse-hide-while-typing = true

# Smooth rendering
window-vsync = true
minimum-contrast = 1.1

# Quick terminal toggle (global hotkey)
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.15

# Keybindings
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom
